// Blue-toned palette overrides for the minimalist look.
// Navy header (theme_color) + a brighter accent blue for links/buttons,
// so the site isn't a single flat blue everywhere.
$link-color              = #2563eb
$link-color-dark         = #5b9aff
$link-hover-color        = #1d4ed8
$link-hover-color-dark   = #8fbcff

$sidebar-highlight       = #2563eb

$btn-default-bg               = #2563eb
$btn-default-bg-dark          = #2563eb
$btn-default-border-color     = #2563eb
$btn-default-border-color-dark = #2563eb
$btn-default-hover-bg         = #1d4ed8
$btn-default-hover-border-color = #1d4ed8
